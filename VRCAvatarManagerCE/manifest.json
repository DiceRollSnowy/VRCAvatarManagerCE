{
    "manifest_version": 3,
    "name": "VRChat Avatar Manager",
    "version": "0.0.1",
    "action": {
        "default_title": "VRChat Avatar Manager"
    },
    "permissions": [
        "cookies",
        "storage"
    ],
    "host_permissions": [
        "https://api.vrchat.cloud/*",
        "https://vrchat.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    }
}